<Window x:Class="openForum.users"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:openForum"
        mc:Ignorable="d"
        Title="users" Height="628" Width="1207">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="#FF67B59D"/>
                <GradientStop Color="#FF387D7B" Offset="1"/>
                <GradientStop Color="#FF65BDB7" Offset="0.508"/>
            </LinearGradientBrush>
        </Grid.Background>
        <Image VerticalAlignment="Bottom" Margin="316,368,318,0" Source="/btn_vissza.png" MaxWidth="150" MaxHeight="70"/>
        <Button VerticalAlignment="Bottom" Name="btnBack" MaxWidth="150" MaxHeight="70" Content="Back" Click="btnBack_Click" Margin="316,340,316,0" Opacity="0" Height="66"/>
        <DataGrid VerticalAlignment="Top" MaxWidth="1600" MaxHeight="1000" Name="dgUsers" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="167,144,167,158" FontFamily="Eras ITC" FontSize="20" SelectionChanged="dgUsers_SelectionChanged"/>
        <TextBox Name="tbSearch" HorizontalAlignment="Center" Margin="0,86,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="204" TextChanged="TextBox_TextChanged" Height="31" FontSize="20" FontFamily="Eras ITC"/>
        <Image VerticalAlignment="Top" Margin="264,0,266,0" MaxWidth="220" MaxHeight="91" Width="270" Height="84" Source="/title_kereses.png"/>
        <TextBox x:Name="name" Opacity="0.5" IsReadOnly="True" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="169,0,0,102" TextWrapping="Wrap" Text="" Width="122" Height="32" FontSize="20" FontFamily="Eras ITC"/>
        <TextBox x:Name="displayname" Opacity="0.5" IsReadOnly="True" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="298,0,0,102" TextWrapping="Wrap" Text="" Width="122" Height="32" FontSize="20" FontFamily="Eras ITC"/>
        <TextBox x:Name="role" Opacity="0.5" IsReadOnly="True" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="425,0,0,102" TextWrapping="Wrap" Text="" Width="37" Height="32" FontSize="20" FontFamily="Eras ITC"/>
        <TextBox x:Name="email" Opacity="0.5" IsReadOnly="True" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="467,0,0,102" TextWrapping="Wrap" Text="" Width="260" Height="32" FontSize="20" FontFamily="Eras ITC"/>
        <Image x:Name="imageModify" Opacity="0.5" HorizontalAlignment="Left" MaxWidth="150" MaxHeight="70" VerticalAlignment="Bottom" Margin="738,0,0,83" Source="/btn_modify.png" Stretch="Fill"/>
        <Button VerticalAlignment="Bottom" Name="btnModify" MaxWidth="150" MaxHeight="70" Content="Back" Click="btnModify_Click" Margin="744,0,0,83" Opacity="0" Height="62" HorizontalAlignment="Left" Width="138"/>
        <Image x:Name="imageBan" Opacity="0.5" HorizontalAlignment="Left" MaxWidth="150" MaxHeight="70" VerticalAlignment="Bottom" Margin="888,0,0,83" Source="/btn_ban.png" Stretch="Fill"/>
        <Image x:Name="imageUnBan" Opacity="0.5" Visibility="Hidden" HorizontalAlignment="Left" MaxWidth="150" MaxHeight="70" VerticalAlignment="Bottom" Margin="888,0,0,83" Source="/btn_unblock.png" Stretch="Fill"/>
        <Button VerticalAlignment="Bottom" Name="btnBan" MaxWidth="150" MaxHeight="70" Content="Ban" Click="btnBan_Click" Margin="894,0,0,88" Opacity="0" Height="62" HorizontalAlignment="Left" Width="138"/>
    </Grid>
</Window>
