<Window x:Class="openForum.users"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:openForum"
        mc:Ignorable="d"
        Title="users" Height="628" Width="1207">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="#FF67B59D"/>
                <GradientStop Color="#FF387D7B" Offset="1"/>
                <GradientStop Color="#FF65BDB7" Offset="0.508"/>
            </LinearGradientBrush>
        </Grid.Background>
        <Image VerticalAlignment="Bottom" Margin="316,368,318,0" Source="/btn_vissza.png" MaxWidth="150" MaxHeight="70"/>
        <Button VerticalAlignment="Bottom" Name="btnBack" MaxWidth="150" MaxHeight="70" Content="Back" Click="btnBack_Click" Margin="316,340,316,0" Opacity="0" Height="66"/>
        <DataGrid VerticalAlignment="Top" MaxWidth="1600" MaxHeight="1000" Name="dgUsers" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="167,144,167,158" FontFamily="Eras ITC" FontSize="20"/>
        <TextBox Name="tbSearch" HorizontalAlignment="Center" Margin="0,86,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="204" TextChanged="TextBox_TextChanged" Height="31" FontSize="20" FontFamily="Eras ITC"/>
        <Image VerticalAlignment="Top" Margin="264,0,266,0" MaxWidth="220" MaxHeight="91" Width="270" Height="84" Source="/title_kereses.png"/>
        <TextBox x:Name="name" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="167,0,0,102" TextWrapping="Wrap" Text="" Width="122" TextChanged="TextBox_TextChanged" Height="32" FontSize="20" FontFamily="Eras ITC"/>
        <TextBox x:Name="displayname" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="294,0,0,102" TextWrapping="Wrap" Text="" Width="122" TextChanged="TextBox_TextChanged" Height="32" FontSize="20" FontFamily="Eras ITC"/>
        <TextBox x:Name="role" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="421,0,0,102" TextWrapping="Wrap" Text="" Width="37" TextChanged="TextBox_TextChanged" Height="32" FontSize="20" FontFamily="Eras ITC"/>
        <TextBox x:Name="email" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="463,0,0,102" TextWrapping="Wrap" Text="" Width="260" TextChanged="TextBox_TextChanged" Height="32" FontSize="20" FontFamily="Eras ITC"/>
        <TextBox x:Name="blocked" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="728,0,0,102" TextWrapping="Wrap" Text="" Width="37" TextChanged="TextBox_TextChanged" Height="32" FontSize="20" FontFamily="Eras ITC"/>
        <Image HorizontalAlignment="Left" MaxWidth="150" MaxHeight="70" VerticalAlignment="Bottom" Margin="770,0,0,83" Source="/btn_modify.png" Stretch="Fill"/>
        <Image HorizontalAlignment="Left" MaxWidth="150" MaxHeight="70" VerticalAlignment="Bottom" Margin="920,0,0,83" Source="/btn_delete.png" Stretch="Fill"/>
        <Button VerticalAlignment="Bottom" Name="btnModify" MaxWidth="150" MaxHeight="70" Content="Back" Click="btnBack_Click" Margin="776,0,0,83" Opacity="0" Height="62" HorizontalAlignment="Left" Width="138"/>
        <Button VerticalAlignment="Bottom" Name="btnDelete" MaxWidth="150" MaxHeight="70" Content="Back" Click="btnBack_Click" Margin="926,0,0,88" Opacity="0" Height="62" HorizontalAlignment="Left" Width="138"/>
    </Grid>
</Window>
