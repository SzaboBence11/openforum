<Window x:Class="openForum.Reports"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:openForum"
        mc:Ignorable="d"
        Title="Reports" Height="628" Width="1207">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="#FF67B59D"/>
                <GradientStop Color="#FF387D7B" Offset="1"/>
                <GradientStop Color="#FF65BDB7" Offset="0.508"/>
            </LinearGradientBrush>
        </Grid.Background>
        <Image VerticalAlignment="Bottom" Margin="316,368,318,0" Source="/btn_vissza.png" MaxWidth="150" MaxHeight="70"/>
        <Button VerticalAlignment="Bottom" Name="btnBack" MaxWidth="150" MaxHeight="70" Content="Back" Click="btnBack_Click" Margin="316,340,316,0" Opacity="0" Height="66"/>
        <DataGrid VerticalAlignment="Top" MaxWidth="1600" MaxHeight="1000" Name="dgReports" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="167,144,167,158" FontFamily="Eras ITC" FontSize="20" SelectionChanged="dgReports_SelectionChanged"/>
        <TextBox Name="tbSearch" HorizontalAlignment="Center" Margin="0,86,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="204" TextChanged="tbSearch_TextChanged" Height="31" FontSize="20" FontFamily="Eras ITC"/>
        <Image VerticalAlignment="Top" Margin="468,0,470,0" MaxWidth="220" MaxHeight="91" Width="270" Height="84" Source="/title_kereses.png"/>
        <Image x:Name="imgDelete" Opacity="0.5" HorizontalAlignment="Left" MaxWidth="150" MaxHeight="70" VerticalAlignment="Bottom" Margin="450,0,0,86" Source="/btn_delete.png" Stretch="Fill"/>
        <Image x:Name="imgBan" Opacity="0.5" HorizontalAlignment="Left" MaxWidth="150" MaxHeight="70" VerticalAlignment="Bottom" Margin="598,0,0,86" Source="/btn_ban.png" Stretch="Fill"/>
        <Button x:Name="btnDelete" VerticalAlignment="Bottom" MaxWidth="150" MaxHeight="70" Content="Back" Margin="456,0,0,90" Opacity="0" Height="62" HorizontalAlignment="Left" Width="138" Click="btnDelete_Click"/>
        <Button x:Name="btnBan" VerticalAlignment="Bottom" MaxWidth="150" MaxHeight="70" Content="Back" Margin="604,0,0,90" Opacity="0" Height="62" HorizontalAlignment="Left" Width="138" Click="btnBan_Click"/>
    </Grid>
</Window>
